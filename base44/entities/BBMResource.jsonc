{
  "name": "BBMResource",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Tajuk BBM"
    },
    "description": {
      "type": "string",
      "description": "Penerangan ringkas BBM"
    },
    "subject": {
      "type": "string",
      "enum": [
        "bahasa_melayu",
        "english",
        "mathematics",
        "science",
        "jawi",
        "bahasa_tamil",
        "bahasa_mandarin",
        "pendidikan_islam",
        "pendidikan_moral",
        "sejarah",
        "rbt",
        "pjk",
        "seni",
        "kafa_quran_jawi",
        "kafa_ulum_syariah",
        "kafa_sirah",
        "kafa_adab",
        "kafa_bahasa_arab"
      ],
      "description": "Subjek Prasekolah dan Sekolah Rendah (termasuk KAFA - Kelas Agama Fardhu Ain)"
    },
    "level": {
      "type": "string",
      "enum": [
        "prasekolah",
        "darjah_1",
        "darjah_2",
        "darjah_3",
        "darjah_4",
        "darjah_5",
        "darjah_6"
      ],
      "description": "Tahap Prasekolah/Darjah"
    },
    "type": {
      "type": "string",
      "enum": [
        "lembaran_kerja",
        "kad_imbasan",
        "carta",
        "slaid_powerpoint",
        "rancangan_pengajaran",
        "modul",
        "kuiz",
        "aktiviti",
        "permainan_bilik_darjah",
        "poster_pendidikan",
        "nota_ringkas",
        "infografik",
        "latihan_pemahaman",
        "latihan_peperiksaan",
        "bahan_pbd",
        "aktiviti_stem",
        "mind_map",
        "latihan_kbat",
        "roleplay",
        "eksperimen_sains",
        "spelling_activity",
        "vocabulary_builder",
        "karangan_builder",
        "teaching_kit"
      ],
      "description": "Jenis BBM"
    },
    "fileUrl": {
      "type": "string",
      "description": "URL fail (PDF, PPT, etc.)"
    },
    "htmlContent": {
      "type": "string",
      "description": "HTML content untuk BBM yang dijana AI (boleh print/save sebagai PDF)"
    },
    "previewImageUrl": {
      "type": "string",
      "description": "Gambar preview BBM"
    },
    "emoji": {
      "type": "string",
      "description": "Emoji ikon"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tag kata kunci"
    },
    "tier": {
      "type": "string",
      "enum": [
        "free",
        "premium"
      ],
      "default": "free",
      "description": "Free atau premium. KAFA BBM kena default premium."
    },
    "downloadCount": {
      "type": "number",
      "default": 0,
      "description": "Bilangan muat turun"
    },
    "isPublished": {
      "type": "boolean",
      "default": true
    },
    "order": {
      "type": "number",
      "description": "Susunan paparan"
    }
  },
  "required": [
    "title",
    "subject",
    "level",
    "type"
  ]
}