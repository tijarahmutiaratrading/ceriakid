{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "gender": {
      "type": "string",
      "enum": [
        "male",
        "female"
      ],
      "description": "User gender for personalized avatar"
    },
    "avatarUrl": {
      "type": "string",
      "description": "Uploaded profile avatar image URL"
    }
  }
}